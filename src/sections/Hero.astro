---
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background grid -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, var(--color-emerald) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-bg-primary"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border bg-bg-surface/50 backdrop-blur-sm mb-8" data-reveal>
      <span class="w-2 h-2 rounded-full bg-emerald animate-pulse"></span>
      <span class="text-text-secondary text-sm font-body">Open Source Sprint Scoring</span>
    </div>

    <!-- Title -->
    <h1 class="font-heading font-extrabold text-5xl sm:text-6xl lg:text-7xl tracking-tight mb-6" data-reveal>
      Stop your AI agent from making the same mistakes twice.
    </h1>

    <!-- Subtitle -->
    <p class="text-text-secondary text-lg sm:text-xl max-w-2xl mx-auto mb-4 leading-relaxed" data-reveal>
      SLOPE is an open-source framework that brings quantified sprint metrics to AI-assisted development. Scorecards, handicap tracking, and real-time guard hooks — across Claude Code, Cursor, Windsurf, Cline, OB1, and OpenCode.
    </p>

    <!-- CTAs -->
    <div class="flex items-center justify-center gap-4 mb-8" data-reveal>
      <a href="#getting-started" class="px-6 py-2.5 rounded-lg bg-emerald text-bg-primary font-heading font-bold text-sm hover:bg-emerald/90 transition-colors">
        Get started
      </a>
      <a href="/docs" class="px-6 py-2.5 rounded-lg border border-border text-text-secondary font-heading font-bold text-sm hover:border-emerald/30 hover:text-text-primary transition-colors">
        See the docs
      </a>
    </div>

    <!-- Live counter -->
    <div class="flex items-center justify-center gap-2 text-text-muted mb-12" data-reveal>
      <span class="w-2 h-2 rounded-full bg-emerald/60 animate-pulse"></span>
      <span class="font-mono text-sm">
        Battle-tested across <span id="hero-sprint-count" class="text-emerald font-medium">69</span> sprints building SLOPE itself — <a href="https://github.com/srbryers/slope/tree/main/docs/retros" target="_blank" rel="noopener noreferrer" class="text-emerald hover:underline">every scorecard is public</a>.
      </span>
    </div>

    <!-- Scroll prompt -->
    <a href="#problem" class="inline-flex flex-col items-center gap-2 text-text-muted hover:text-emerald transition-colors group" data-reveal>
      <span class="text-sm font-body">See how it works</span>
      <div class="animate-bounce">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="mx-auto" aria-hidden="true">
          <path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
    </a>
  </div>
</section>

<script>
  import { initLiveStats, onStatsUpdate } from '../scripts/live-stats';
  import { animateCounter } from '../scripts/animations';

  const counter = document.getElementById('hero-sprint-count');
  if (counter) {
    onStatsUpdate((stats) => {
      animateCounter(counter, stats.sprints_completed, 1.5);
    });
  }
  initLiveStats();
</script>
