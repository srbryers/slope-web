---
---

<section id="cta" class="py-24 sm:py-32 bg-bg-surface/50">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-12" data-reveal>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl mb-4">
        Make your next sprint the last one your agent flies blind.
      </h2>
      <p class="text-text-secondary max-w-xl mx-auto">
        Every sprint without structured feedback is a sprint where the same mistakes repeat. The compounding starts when you do.
      </p>
    </div>

    <!-- Three paths -->
    <div class="grid sm:grid-cols-3 gap-6 mb-12" data-stagger>
      <!-- Primary: action -->
      <div class="rounded-xl border border-emerald/20 bg-bg-card p-6 text-center">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-2">Install and run</h3>
        <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-lg border border-border bg-bg-surface font-mono text-sm mb-4">
          <span class="text-text-muted">$</span>
          <code class="text-emerald">npm install -g @slope-dev/slope</code>
        </div>
        <p class="text-text-muted text-xs">First scorecard in ~15 minutes</p>
      </div>

      <!-- Secondary: guide -->
      <div class="rounded-xl border border-border bg-bg-card p-6 text-center">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-2">Not ready to install?</h3>
        <p class="text-text-muted text-sm mb-4">
          Walk through a full sprint lifecycle in 2 minutes — no install needed.
        </p>
        <a
          href="/guide"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-emerald text-bg-primary font-heading font-bold text-sm hover:bg-emerald/90 transition-colors"
        >
          Try the guide
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <!-- Tertiary: docs -->
      <div class="rounded-xl border border-border bg-bg-card p-6 text-center">
        <h3 class="font-heading font-bold text-lg text-text-primary mb-2">Read the framework</h3>
        <p class="text-text-muted text-sm mb-4">
          Scoring engine, workflow system, guards, and the complete methodology.
        </p>
        <a
          href="/docs"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-border text-text-secondary font-heading font-bold text-sm hover:border-emerald/30 hover:text-text-primary transition-colors"
        >
          Full reference
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Packages inline mention -->
    <div class="text-center mb-8" data-reveal>
      <p class="text-text-muted text-xs font-mono">
        @slope-dev/slope
      </p>
    </div>

    <!-- Footer -->
    <div class="text-center text-text-muted text-xs" data-reveal>
      <p>
        SLOPE is an open-source sprint scoring framework for AI agent teams.
      </p>
      <p class="mt-2">
        Built with Astro, Tailwind, and GSAP. Live stats from the reference implementation.
      </p>
    </div>
  </div>
</section>
