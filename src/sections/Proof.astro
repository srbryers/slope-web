---
---

<section id="proof" class="py-24 sm:py-32">
  <div class="max-w-4xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-12" data-reveal>
      <p class="text-emerald text-xs font-mono uppercase tracking-widest mb-3">It Works</p>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl mb-4">
        Consistent routines compound.
      </h2>
      <p class="text-text-secondary max-w-2xl mx-auto text-sm">
        Across <span id="proof-sample-size" class="text-emerald font-medium">69</span> sprints on the SLOPE monorepo. Estimation accuracy = par vs actual score. Delivery accuracy = tickets completed vs planned.
      </p>
    </div>

    <!-- Stats wall -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 mb-10" data-reveal>
      <div class="rounded-xl border border-border bg-bg-card p-6 text-center">
        <div class="flex items-baseline justify-center">
          <span id="proof-fairway" class="text-4xl sm:text-5xl font-heading font-bold text-emerald">94</span>
          <span class="text-2xl text-emerald/60">%</span>
        </div>
        <p class="text-text-muted text-xs font-mono uppercase tracking-wider mt-2">Estimation Accuracy</p>
        <p class="text-text-secondary text-xs mt-1">How often sprint scoping is on target</p>
      </div>

      <div class="rounded-xl border border-border bg-bg-card p-6 text-center">
        <div class="flex items-baseline justify-center">
          <span id="proof-gir" class="text-4xl sm:text-5xl font-heading font-bold text-emerald">75</span>
          <span class="text-2xl text-emerald/60">%</span>
        </div>
        <p class="text-text-muted text-xs font-mono uppercase tracking-wider mt-2">Delivery Accuracy</p>
        <p class="text-text-secondary text-xs mt-1">How often tickets land as planned</p>
      </div>

      <div class="rounded-xl border border-border bg-bg-card p-6 text-center">
        <div class="flex items-baseline justify-center">
          <span id="proof-handicap" class="text-4xl sm:text-5xl font-heading font-bold text-emerald">0.2</span>
        </div>
        <p class="text-text-muted text-xs font-mono uppercase tracking-wider mt-2">Performance Index</p>
        <p class="text-text-secondary text-xs mt-1">Overall rating (lower is better)</p>
      </div>
    </div>

    <!-- Sprint 12 anecdote — visual callout -->
    <div class="max-w-2xl mx-auto mb-8" data-reveal>
      <div class="rounded-xl border border-emerald/20 bg-emerald/5 p-5 text-center">
        <p class="text-text-primary font-heading font-bold text-base mb-2">Sprint 12</p>
        <p class="text-text-secondary leading-relaxed">
          The same CSS z-index bug appeared for the third time. SLOPE flagged it as a recurring hazard. It never appeared again.
        </p>
        <p class="text-text-muted text-xs mt-2 italic">Retrospectives with data instead of feelings.</p>
      </div>
    </div>

    <!-- Source + methodology -->
    <div class="text-center max-w-2xl mx-auto" data-reveal>
      <p class="text-text-muted text-sm mb-3">
        Every metric on this page comes from the reference implementation — <span id="proof-sprint-total" class="text-emerald font-medium">69</span> sprints of real work, scored with the same framework you install.
      </p>
      <a href="https://github.com/srbryers/slope/tree/main/docs/retros" target="_blank" rel="noopener noreferrer" class="text-emerald text-sm font-medium hover:underline">
        View the scorecards &rarr;
      </a>
    </div>
  </div>
</section>

<script>
  import { onStatsUpdate } from '../scripts/live-stats';
  import { animateCounter } from '../scripts/animations';

  const fairwayEl = document.getElementById('proof-fairway');
  const girEl = document.getElementById('proof-gir');
  const handicapEl = document.getElementById('proof-handicap');
  const totalEl = document.getElementById('proof-sprint-total');
  const sampleEl = document.getElementById('proof-sample-size');

  onStatsUpdate((stats) => {
    const h = stats.handicap?.all_time;
    if (!h) return;

    if (fairwayEl) animateCounter(fairwayEl, Math.round(h.fairway_pct));
    if (girEl) animateCounter(girEl, Math.round(h.gir_pct));
    if (handicapEl) handicapEl.textContent = h.handicap.toFixed(1);
    if (totalEl) animateCounter(totalEl, stats.sprints_completed);
    if (sampleEl) animateCounter(sampleEl, stats.sprints_completed);
  });
</script>
