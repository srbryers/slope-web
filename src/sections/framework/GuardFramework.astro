---
import { GUARDS } from '../../data/manifest';
import type { ManifestGuard } from '../../data/manifest';

// Group guards by name to handle multi-hook guards (e.g. sprint-completion has 3 hooks)
interface GroupedGuard {
  name: string;
  hooks: { hookEvent: string; matcher?: string; description: string }[];
}

const grouped: GroupedGuard[] = [];
const seen = new Map<string, number>();
for (const guard of GUARDS) {
  const idx = seen.get(guard.name);
  if (idx !== undefined) {
    grouped[idx].hooks.push({ hookEvent: guard.hookEvent, matcher: guard.matcher, description: guard.description });
  } else {
    seen.set(guard.name, grouped.length);
    grouped.push({ name: guard.name, hooks: [{ hookEvent: guard.hookEvent, matcher: guard.matcher, description: guard.description }] });
  }
}
const uniqueCount = grouped.length;
const multiHookCount = grouped.filter(g => g.hooks.length > 1).length;
---

<!-- Guard Framework -->
<section id="guard-framework" class="mb-16 scroll-mt-20">
  <h2 class="font-heading font-bold text-2xl mb-4 text-text-primary">Guard Framework</h2>
  <p class="text-text-secondary mb-6">{uniqueCount} built-in guards that enforce discipline automatically via Claude Code hooks. Guards fire on tool use events and provide real-time warnings.</p>

  <div class="rounded-xl border border-border bg-bg-card overflow-hidden mb-6">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border bg-bg-surface/50">
          <th class="text-left px-5 py-3 text-text-muted text-xs uppercase tracking-wider font-medium">Guard</th>
          <th class="text-left px-5 py-3 text-text-muted text-xs uppercase tracking-wider font-medium">Trigger</th>
          <th class="text-left px-5 py-3 text-text-muted text-xs uppercase tracking-wider font-medium hidden sm:table-cell">Matches</th>
          <th class="text-left px-5 py-3 text-text-muted text-xs uppercase tracking-wider font-medium">Purpose</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border-subtle">
        {grouped.map((guard) => (
          <tr>
            <td class="px-5 py-3 text-emerald font-mono text-xs">
              {guard.name}
              {guard.hooks.length > 1 && (
                <span class="ml-1 text-[10px] text-text-muted font-sans">({guard.hooks.length} hooks)</span>
              )}
            </td>
            <td class="px-5 py-3 text-text-muted text-xs">
              {guard.hooks.length === 1
                ? guard.hooks[0].hookEvent
                : guard.hooks.map(h => h.hookEvent).join(', ')}
            </td>
            <td class="px-5 py-3 text-amber-400/80 font-mono text-[11px] hidden sm:table-cell">
              {guard.hooks.length === 1
                ? (guard.hooks[0].matcher || '\u2014')
                : guard.hooks.map(h => h.matcher || '\u2014').filter((v, i, a) => a.indexOf(v) === i).join(', ')}
            </td>
            <td class="px-5 py-3 text-text-secondary text-xs">{guard.hooks[0].description}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="text-text-muted text-sm">Guards are installed via <code class="text-emerald bg-bg-primary px-1.5 py-0.5 rounded text-xs">slope hook add --level=full</code> and can be extended with custom guards through the plugin system.</p>
</section>
