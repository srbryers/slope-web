<!-- Inspiration Tracking -->
<section id="inspiration-tracking" class="mb-16 scroll-mt-20">
  <h2 class="font-heading font-bold text-2xl mb-4 text-text-primary">Inspiration Tracking</h2>
  <p class="text-text-secondary mb-6">Track external OSS projects and ideas you want to adapt into your codebase. Link inspirations to sprints so the context travels with the work.</p>

  <div class="space-y-3 mb-6">
    {[
      { cmd: 'slope inspirations add', desc: 'Register an OSS project with extracted ideas' },
      { cmd: 'slope inspirations list', desc: 'Show tracked inspirations, filterable by status' },
      { cmd: 'slope inspirations link', desc: 'Link an inspiration to a sprint for context' },
    ].map(({ cmd, desc }) => (
      <div class="flex items-center gap-3 p-3 rounded-lg bg-bg-card border border-border-subtle">
        <code class="text-emerald text-xs font-mono shrink-0">{cmd}</code>
        <span class="text-text-muted text-sm">{desc}</span>
      </div>
    ))}
  </div>

  <p class="text-text-muted text-sm">Inspirations are stored in <code class="text-emerald bg-bg-primary px-1.5 py-0.5 rounded text-xs">.slope/inspirations.json</code> and accessible via MCP: <code class="text-emerald bg-bg-primary px-1.5 py-0.5 rounded text-xs">search({'{'} module: 'inspirations' {'}'})</code> returns all tracked sources, filterable by status or project name.</p>
</section>
