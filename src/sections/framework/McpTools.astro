---
import { MCP_TOOLS } from '../../data/manifest';
import type { ManifestTool, ManifestToolParam } from '../../data/manifest';

const coreTools = MCP_TOOLS.filter((t) => !t.requiresStore);
const storeTools = MCP_TOOLS.filter((t) => t.requiresStore);
---

<!-- MCP Tools -->
<section id="mcp-tools" class="mb-16 scroll-mt-20">
  <h2 class="font-heading font-bold text-2xl mb-4 text-text-primary">MCP Tools</h2>
  <p class="text-text-secondary mb-6">{MCP_TOOLS.length} tools available via the SLOPE MCP server — {coreTools.length} core tools (no store required) and {storeTools.length} store-backed tools for session and claim management.</p>

  <!-- Core tools -->
  <h3 class="text-xs font-mono uppercase tracking-wider text-text-muted mb-3">Core</h3>
  <div class="space-y-2 mb-8">
    {coreTools.map((tool: ManifestTool) => (
      <details class="group rounded-lg border border-border-subtle bg-bg-card overflow-hidden">
        <summary class="flex items-center gap-3 p-3 cursor-pointer hover:bg-bg-surface/50 transition-colors list-none [&::-webkit-details-marker]:hidden">
          <svg class="w-3.5 h-3.5 text-text-muted transition-transform group-open:rotate-90 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <code class="text-emerald text-xs font-mono shrink-0">{tool.name}</code>
          <span class="text-text-muted text-xs">{tool.desc}</span>
        </summary>
        <div class="px-3 pb-3 pt-1 border-t border-border-subtle/50">
          {tool.params && tool.params.length > 0 ? (
            <div class="mt-2">
              <p class="text-[10px] uppercase tracking-wider text-text-muted mb-1.5">Parameters</p>
              <div class="space-y-1">
                {tool.params.map((p: ManifestToolParam) => (
                  <div class="flex items-start gap-2 text-xs">
                    <code class="text-amber-400 font-mono text-[11px] shrink-0">
                      {p.name}{p.required ? '' : '?'}
                    </code>
                    <span class="text-text-muted/60 font-mono text-[10px] shrink-0">{p.type}</span>
                    <span class="text-text-muted">{p.desc}</span>
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <p class="text-text-muted text-xs mt-1">No parameters.</p>
          )}
        </div>
      </details>
    ))}
  </div>

  <!-- Store-backed tools -->
  <h3 class="text-xs font-mono uppercase tracking-wider text-text-muted mb-3">Store-Backed</h3>
  <div class="space-y-2 mb-6">
    {storeTools.map((tool: ManifestTool) => (
      <details class="group rounded-lg border border-border-subtle bg-bg-card overflow-hidden">
        <summary class="flex items-center gap-3 p-3 cursor-pointer hover:bg-bg-surface/50 transition-colors list-none [&::-webkit-details-marker]:hidden">
          <svg class="w-3.5 h-3.5 text-text-muted transition-transform group-open:rotate-90 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <code class="text-emerald text-xs font-mono shrink-0">{tool.name}</code>
          <span class="text-text-muted text-xs">{tool.desc}</span>
          <span class="ml-auto text-[10px] text-text-muted bg-bg-surface px-1.5 py-0.5 rounded-full shrink-0">store</span>
        </summary>
        <div class="px-3 pb-3 pt-1 border-t border-border-subtle/50">
          {tool.params && tool.params.length > 0 ? (
            <div class="mt-2">
              <p class="text-[10px] uppercase tracking-wider text-text-muted mb-1.5">Parameters</p>
              <div class="space-y-1">
                {tool.params.map((p: ManifestToolParam) => (
                  <div class="flex items-start gap-2 text-xs">
                    <code class="text-amber-400 font-mono text-[11px] shrink-0">
                      {p.name}{p.required ? '' : '?'}
                    </code>
                    <span class="text-text-muted/60 font-mono text-[10px] shrink-0">{p.type}</span>
                    <span class="text-text-muted">{p.desc}</span>
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <p class="text-text-muted text-xs mt-1">No parameters.</p>
          )}
        </div>
      </details>
    ))}
  </div>

  <p class="text-text-muted text-sm">Configure via <code class="text-emerald bg-bg-primary px-1.5 py-0.5 rounded text-xs">.mcp.json</code> in your project root. Requires <code class="text-emerald bg-bg-primary px-1.5 py-0.5 rounded text-xs">pnpm -r build</code> before first use. Store-backed tools require an active SLOPE store (<code class="text-emerald bg-bg-primary px-1.5 py-0.5 rounded text-xs">.slope/slope.db</code>).</p>
</section>
