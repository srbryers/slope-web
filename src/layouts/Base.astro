---
import Nav from '../components/Nav.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const SITE_URL = 'https://getslope.dev';

const {
  title = 'SLOPE — Open-Source Sprint Scoring for AI Coding Agents',
  description = 'Open-source sprint scoring framework for AI coding agents. Scorecards, handicap tracking, workflow orchestration, and real-time guard hooks for Claude Code, Cursor, Windsurf, and more.',
  canonicalPath = '',
} = Astro.props;

const canonicalURL = `${SITE_URL}${canonicalPath}`;
const ogImageURL = `${SITE_URL}/og.png?v=3`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0F1210" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="SLOPE" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- FOUC prevention: apply saved metaphor before first paint -->
    <script is:inline>
      (function(){var m=localStorage.getItem('slope-metaphor');if(m)document.documentElement.dataset.metaphor=m;})();
    </script>

    <!-- Analytics (Umami — cookieless, GDPR-compliant) -->
    {import.meta.env.PROD && import.meta.env.PUBLIC_UMAMI_ID && (
      <script defer src="https://cloud.umami.is/script.js" data-website-id={import.meta.env.PUBLIC_UMAMI_ID}></script>
    )}

    <!-- Structured Data: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "SLOPE",
      "url": SITE_URL,
      "description": "A framework for measuring and improving AI agent sprint performance — with golf-inspired scoring.",
      "creator": {
        "@type": "Organization",
        "name": "SLOPE",
        "url": "https://getslope.dev",
        "sameAs": [
          "https://github.com/srbryers/slope",
          "https://www.npmjs.com/package/@slope-dev/slope"
        ]
      }
    })} />

    <!-- Structured Data: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "SLOPE",
      "description": "Open-source sprint scoring framework for AI coding agents. Scorecards, handicap tracking, workflow orchestration, and real-time guard hooks.",
      "url": SITE_URL,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Cross-platform (Node.js)",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "license": "https://opensource.org/licenses/MIT",
      "codeRepository": "https://github.com/srbryers/slope",
      "softwareVersion": "1.49.0",
      "programmingLanguage": "TypeScript"
    })} />
  </head>
  <body>
    <Nav currentPath={Astro.url.pathname} />
    <div class="h-14"></div>

    <slot />

    <script>
      import { initMetaphorSwitcher } from '../scripts/interactions';
      initMetaphorSwitcher();
    </script>
  </body>
</html>
