---
import Base from '../layouts/Base.astro';
import Hero from '../sections/Hero.astro';
import Problem from '../sections/Problem.astro';
import HowItRuns from '../sections/HowItRuns.astro';
import Languages from '../sections/Languages.astro';
import Proof from '../sections/Proof.astro';
import GettingStarted from '../sections/GettingStarted.astro';
import CTA from '../sections/CTA.astro';
import '../styles/global.css';
---

<Base
  title="SLOPE — Sprint Scoring for AI Coding Agents"
  description="Open-source framework for quantified sprint metrics in AI-assisted development. Scorecards, handicap tracking, workflow orchestration, and real-time guard hooks for Claude Code, Cursor, Windsurf, Codex CLI, and more."
>
  <main>
    <Hero />
    <Problem />
    <HowItRuns />
    <Languages />
    <Proof />
    <GettingStarted />
    <CTA />
  </main>
</Base>

<script>
  import { initAnimations } from '../scripts/animations';

  document.addEventListener('DOMContentLoaded', () => {
    initAnimations();
  });
</script>
